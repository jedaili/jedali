{
  "name": "my-ai-desktop",
  "version": "1.0.0",
  "description": "Cursor-like desktop IDE powered by your local AI agent",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:ui": "vite build",
    "test": "vitest run",
    "preview": "vite preview --host",
    "rebuild:native": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.383.0",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.myai.desktop",
    "productName": "My AI Desktop",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
